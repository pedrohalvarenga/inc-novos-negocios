generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                  String     @id @default(cuid())
  supabaseId          String     @unique
  nome                String
  email               String     @unique
  role                Role       @default(ANALISTA)
  ativo               Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  auditLogs           AuditLog[]
  propostasCriadas    Proposta[]
  terrenosCriados     Terreno[]  @relation("TerrenoCriador")
  terrenosResponsavel Terreno[]  @relation("TerrenoResponsavel")

  @@map("usuarios")
}

model Terreno {
  id                        String                   @id @default(cuid())
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  nome                      String
  apelido                   String?
  logradouro                String
  numero                    String?
  complemento               String?
  bairro                    String
  cidade                    String
  uf                        String                   @db.Char(2)
  cep                       String?
  lat                       Float?
  lng                       Float?
  areaTerreno               Float
  origem                    OrigemTerreno            @default(MANUAL)
  zenkitItemId              String?
  dataProspeccao            DateTime                 @default(now())
  zoneamento                String?
  coeficienteAproveitamento Float?
  numUnidadesEstimado       Int?
  areaPrivativaMedia        Float?
  vgvEstimado               Float?
  valorPedido               Float?
  valorCompra               Float?
  formaPagamento            FormaPagamento?
  prazoPagamento            Int?
  percentualPermuta         Float?
  descricaoPermuta          String?
  status                    StatusTerreno            @default(PROSPECCAO)
  createdBy                 String
  responsavelId             String?
  corretorId                String?
  auditLogs                 AuditLog[]
  contratos                 Contrato[]
  dueDiligences             DueDiligence[]
  lancamentos               LancamentoFinanceiro[]
  matriculas                Matricula[]
  propostas                 Proposta[]
  proprietarios             TerrenoProprietario[]
  statusHistorico           TerrenoStatusHistorico[]
  corretor                  Corretor?                @relation(fields: [corretorId], references: [id])
  criador                   Usuario                  @relation("TerrenoCriador", fields: [createdBy], references: [id])
  responsavel               Usuario?                 @relation("TerrenoResponsavel", fields: [responsavelId], references: [id])

  @@map("terrenos")
}

model TerrenoStatusHistorico {
  id             String         @id @default(cuid())
  terrenoId      String
  statusAnterior StatusTerreno?
  statusNovo     StatusTerreno
  observacao     String?
  createdAt      DateTime       @default(now())
  createdBy      String
  terreno        Terreno        @relation(fields: [terrenoId], references: [id], onDelete: Cascade)

  @@map("terreno_status_historico")
}

model Proprietario {
  id                 String                @id @default(cuid())
  nomeRazaoSocial    String
  cpfCnpj            String?
  telefone           String?
  email              String?
  representanteLegal String?
  observacoes        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String
  dueDiligences      DueDiligence[]
  terrenos           TerrenoProprietario[]

  @@map("proprietarios")
}

model TerrenoProprietario {
  id             String       @id @default(cuid())
  terrenoId      String
  proprietarioId String
  percentual     Float?
  principal      Boolean      @default(false)
  proprietario   Proprietario @relation(fields: [proprietarioId], references: [id])
  terreno        Terreno      @relation(fields: [terrenoId], references: [id], onDelete: Cascade)

  @@unique([terrenoId, proprietarioId])
  @@map("terreno_proprietarios")
}

model Corretor {
  id                 String    @id @default(cuid())
  nome               String
  telefone           String?
  email              String?
  creci              String?
  percentualComissao Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String
  terrenos           Terreno[]

  @@map("corretores")
}

model Proposta {
  id                 String          @id @default(cuid())
  terrenoId          String
  versao             Int             @default(1)
  dataEnvio          DateTime?
  validade           DateTime?
  valorProposto      Float?
  formaPagamento     FormaPagamento?
  prazo              Int?
  percentualPermuta  Float?
  condicoesEspeciais String?
  status             StatusProposta  @default(RASCUNHO)
  motivoRecusa       String?
  baseParaContrato   Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  createdBy          String
  contratos          Contrato[]
  criador            Usuario         @relation(fields: [createdBy], references: [id])
  terreno            Terreno         @relation(fields: [terrenoId], references: [id])

  @@map("propostas")
}

model Contrato {
  id             String                 @id @default(cuid())
  terrenoId      String
  propostaId     String?
  versao         Int                    @default(1)
  clausulas      Json?
  status         StatusContrato         @default(MINUTA)
  dataAssinatura DateTime?
  dataVencimento DateTime?
  observacoes    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      String
  proposta       Proposta?              @relation(fields: [propostaId], references: [id])
  terreno        Terreno                @relation(fields: [terrenoId], references: [id])
  lancamentos    LancamentoFinanceiro[]

  @@map("contratos")
}

model Matricula {
  id             String     @id @default(cuid())
  terrenoId      String
  numero         String?
  cartorio       String?
  comarca        String?
  dadosExtraidos Json?
  arquivos       Json?
  onus           Json?
  riscoOnus      RiscoOnus?
  observacoes    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  createdBy      String
  terreno        Terreno    @relation(fields: [terrenoId], references: [id])

  @@map("matriculas")
}

model DueDiligence {
  id             String                    @id @default(cuid())
  proprietarioId String
  terrenoId      String?
  tipo           TipoDocumentoDueDiligence
  dataAnalise    DateTime?
  fonte          String?
  resultado      Json?
  checklist      Json?
  resumo         String?
  score          Float?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  createdBy      String
  proprietario   Proprietario              @relation(fields: [proprietarioId], references: [id])
  terreno        Terreno?                  @relation(fields: [terrenoId], references: [id])

  @@map("due_diligences")
}

model LancamentoFinanceiro {
  id                String                   @id @default(cuid())
  terrenoId         String
  contratoId        String?
  tipo              TipoLancamentoFinanceiro
  descricao         String?
  valor             Float
  vencimento        DateTime?
  status            StatusLancamento         @default(PREVISTO)
  dataPagamento     DateTime?
  comprovante       String?
  recorrente        Boolean                  @default(false)
  recorrencia       String?
  recorrenciaConfig Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  createdBy         String
  contrato          Contrato?                @relation(fields: [contratoId], references: [id])
  terreno           Terreno                  @relation(fields: [terrenoId], references: [id])

  @@map("lancamentos_financeiros")
}

model AuditLog {
  id              String        @id @default(cuid())
  usuarioId       String?
  terrenoId       String?
  tipo            TipoAuditoria
  entidade        String
  entidadeId      String
  camposAlterados Json?
  descricao       String?
  createdAt       DateTime      @default(now())
  terreno         Terreno?      @relation(fields: [terrenoId], references: [id])
  usuario         Usuario?      @relation(fields: [usuarioId], references: [id])

  @@map("audit_logs")
}

model Notificacao {
  id        String   @id @default(cuid())
  usuarioId String?
  tipo      String
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  payload   Json?
  createdAt DateTime @default(now())

  @@map("notificacoes")
}

model ZenkitSyncLog {
  id          String    @id @default(cuid())
  iniciado    DateTime  @default(now())
  concluido   DateTime?
  criados     Int       @default(0)
  atualizados Int       @default(0)
  erros       Int       @default(0)
  log         Json?
  status      String    @default("EM_ANDAMENTO")

  @@map("zenkit_sync_logs")
}

model Configuracao {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("configuracoes")
}

enum Role {
  ADMIN
  GESTOR
  ANALISTA
  LEITURA
}

enum OrigemTerreno {
  ZENKIT
  MANUAL
}

enum FormaPagamento {
  PERMUTA_FISICA
  PERMUTA_FINANCEIRA
  DINHEIRO_PRAZO
  DINHEIRO_VISTA
  MISTO
}

enum StatusTerreno {
  PROSPECCAO
  EM_NEGOCIACAO
  PROPOSTA_ENVIADA
  PROPOSTA_ACEITA
  CONTRATO_EM_ELABORACAO
  CONTRATO_ASSINADO
  DESCARTADO
}

enum StatusProposta {
  RASCUNHO
  ENVIADA
  EM_NEGOCIACAO
  ACEITA
  RECUSADA
  EXPIRADA
}

enum StatusContrato {
  MINUTA
  EM_REVISAO
  ANALISE_JURIDICA
  APROVADO
  ASSINADO
  RESCINDIDO
}

enum RiscoOnus {
  BAIXO
  MEDIO
  ALTO
  IMPEDITIVO
}

enum TipoDocumentoDueDiligence {
  CPF
  CNPJ
}

enum TipoLancamentoFinanceiro {
  PARCELA_TERRENISTA
  IPTU
  MANUTENCAO
  CERCA
  COMISSAO
  CARTORIO
  OUTROS
}

enum StatusLancamento {
  PREVISTO
  A_PAGAR
  PAGO
  ATRASADO
}

enum TipoAuditoria {
  CREATE
  UPDATE
  DELETE
}

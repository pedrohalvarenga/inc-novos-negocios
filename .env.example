# Supabase — Settings > API Keys > Publishable key
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Supabase — Settings > API Keys > Secret keys (NUNCA exponha no front-end)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Prisma — Settings > Database > Connection string (Transaction Pooler porta 6543)
DATABASE_URL="postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.SEU_PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"

# Zenkit (opcional — sincronização de leads)
# ZENKIT_API_KEY=
# ZENKIT_WORKSPACE_ID=

# Anthropic (opcional — análise automática via IA; sem esta chave o modo híbrido manual fica ativo)
# ANTHROPIC_API_KEY=
